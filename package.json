{
  "name": "@tencent/teamai-cli",
  "version": "0.13.1",
  "description": "TeamAI — 团队 AI 经验共享框架",
  "type": "module",
  "bin": {
    "teamai": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "http://r.tnpm.oa.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "release": "standard-version",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://git.woa.com/teamai/teamai-cli.git"
  },
  "keywords": [
    "ai",
    "team",
    "devkit",
    "skills",
    "sharing"
  ],
  "author": "jeffyxu",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^2.1.9",
    "standard-version": "^9.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
